{
  "name": "Universal Dev Template",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "chmod +x scripts/*.sh && ./scripts/start.sh diagnose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
